

<style>
  .ex-wrap { padding: 1rem 0; font-family: var(--font-sans); }
  .progress-bar { height: 6px; background: var(--color-border-tertiary); border-radius: 3px; margin-bottom: 1.5rem; }
  .progress-fill { height: 100%; border-radius: 3px; background: #1D9E75; transition: width 0.4s; }
  .question-box { background: var(--color-background-secondary); border-radius: var(--border-radius-lg); padding: 1.25rem 1.5rem; margin-bottom: 1rem; }
  .sentence { font-size: 18px; color: var(--color-text-primary); margin-bottom: 1rem; line-height: 1.6; }
  .answer-input { font-size: 16px; border: 0.5px solid var(--color-border-secondary); border-radius: var(--border-radius-md); padding: 8px 12px; width: 100%; box-sizing: border-box; background: var(--color-background-primary); color: var(--color-text-primary); }
  .answer-input:focus { outline: none; border-color: #378ADD; box-shadow: 0 0 0 2px rgba(55,138,221,0.2); }
  .btn { cursor: pointer; padding: 9px 20px; border-radius: var(--border-radius-md); font-size: 15px; border: 0.5px solid var(--color-border-secondary); background: var(--color-background-primary); color: var(--color-text-primary); }
  .btn:hover { background: var(--color-background-secondary); }
  .btn-primary { background: #1D9E75; color: white; border-color: #1D9E75; }
  .btn-primary:hover { background: #0F6E56; border-color: #0F6E56; }
  .feedback { border-radius: var(--border-radius-md); padding: 10px 14px; font-size: 15px; margin-top: 10px; display: none; }
  .feedback.correct { background: #EAF3DE; color: #27500A; display: block; }
  .feedback.wrong { background: #FCEBEB; color: #791F1F; display: block; }
  .nav-row { display: flex; gap: 8px; align-items: center; margin-top: 12px; flex-wrap: wrap; }
  .counter { font-size: 13px; color: var(--color-text-secondary); margin-left: auto; }
  .score-box { text-align: center; padding: 2rem; }
  .score-num { font-size: 48px; font-weight: 500; color: #1D9E75; }
  .score-label { font-size: 14px; color: var(--color-text-secondary); margin-top: 4px; }
</style>

<div class="ex-wrap">
  <div class="progress-bar"><div class="progress-fill" id="prog" style="width:0%"></div></div>
  <div id="main"></div>
</div>

<script>
const questions = [
  { sentence: "Hier, je ___ une pizza. (manger)", answer: "ai mangé" },
  { sentence: "Elle ___ un film hier soir. (regarder)", answer: "a regardé" },
  { sentence: "Nous ___ beaucoup au café ce matin. (parler)", answer: "avons parlé" },
  { sentence: "Tu ___ tes devoirs ? (finir)", answer: "as fini" },
  { sentence: "Ils ___ un gâteau pour mon anniversaire. (faire)", answer: "ont fait" },
  { sentence: "Je n'___ pas ___ mes clés. (trouver)", answer: "ai trouvé", negation: true, full: "Je n'ai pas trouvé mes clés." },
  { sentence: "Vous ___ la tour Eiffel ? (voir)", answer: "avez vu" },
  { sentence: "Il ___ un livre très intéressant. (lire)", answer: "a lu" },
];

let current = 0, score = 0, answered = false;

function normalize(s) {
  return s.trim().toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "").replace(/\s+/g, " ");
}

function render() {
  const q = questions[current];
  document.getElementById('prog').style.width = (current / questions.length * 100) + '%';

  document.getElementById('main').innerHTML = `
    <div class="question-box">
      <div class="sentence">${q.sentence}</div>
      <input class="answer-input" id="ans" type="text" placeholder="Conjuguez le verbe..." autocomplete="off" />
      <div class="feedback" id="fb"></div>
    </div>
    <div class="nav-row">
      <button class="btn btn-primary" onclick="check()">Vérifier</button>
      ${current < questions.length - 1
        ? `<button class="btn" id="nextBtn" onclick="next()" style="display:none">Question suivante →</button>`
        : `<button class="btn" id="nextBtn" onclick="showScore()" style="display:none">Voir les résultats →</button>`}
      <span class="counter">${current + 1} / ${questions.length}</span>
    </div>
  `;

  document.getElementById('ans').addEventListener('keydown', e => { if (e.key === 'Enter') check(); });
  setTimeout(() => document.getElementById('ans').focus(), 50);
  answered = false;
}

function check() {
  if (answered) return;
  const q = questions[current];
  const val = document.getElementById('ans').value;
  const fb = document.getElementById('fb');
  const nextBtn = document.getElementById('nextBtn');
  if (!val.trim()) { fb.textContent = "Entrez une réponse !"; fb.className = 'feedback wrong'; return; }

  answered = true;
  document.getElementById('ans').disabled = true;

  if (normalize(val) === normalize(q.answer)) {
    score++;
    fb.textContent = "Correct !";
    fb.className = 'feedback correct';
  } else {
    fb.innerHTML = `Pas tout à fait. La bonne réponse : <strong>${q.negation ? q.full : q.answer}</strong>`;
    fb.className = 'feedback wrong';
  }
  nextBtn.style.display = 'inline-block';
}

function next() { current++; render(); }

function showScore() {
  document.getElementById('prog').style.width = '100%';
  const pct = Math.round(score / questions.length * 100);
  const msg = pct >= 80 ? "Excellent travail !" : pct >= 50 ? "Bon début, continuez !" : "Encore un peu de pratique !";
  document.getElementById('main').innerHTML = `
    <div class="score-box">
      <div class="score-num">${score}/${questions.length}</div>
      <div class="score-label">${msg}</div>
      <div style="margin-top:1.5rem;">
        <button class="btn" onclick="restart()">Recommencer</button>
      </div>
    </div>
  `;
}

function restart() { current = 0; score = 0; answered = false; render(); }
render();
</script>
